<!-- In-use/locked badge backdrop on a gallery tile in Selection Mode. Sits
     over arbitrary photo content (not a themed surface), so - like a video
     duration badge - it uses a fixed translucent scrim rather than a theme
     color role, to stay legible against any image. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="#99000000" />
</shape>
