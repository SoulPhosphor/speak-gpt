<!-- Unused / Missing text pill on a gallery tile (FILTERS: "Unused tiles may
     have a subtle Unused label. Do not rely solely on a border color to
     communicate status."). Sits over arbitrary photo content, so - like the
     locked badge - it uses a fixed translucent scrim rather than a theme
     surface color, to stay legible against any image underneath it. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#99000000" />
    <corners android:radius="4dp" />
</shape>
