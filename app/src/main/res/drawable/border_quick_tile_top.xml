<!-- Thin subtle border for the TOP tile of the Quick Settings container block
     (owner ruling, July 21 2026). Drawn as a FOREGROUND over the tile so the
     existing fill/tint is untouched: transparent fill + a 1dp stroke, corners
     matching btn_accent_top (24dp top, 4dp bottom) so the line traces the tile
     exactly. The stroke colour lives in one place (@color/quick_tile_border)
     for the coming theming pass. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="@color/quick_tile_border" />
    <corners
        android:topLeftRadius="24dp"
        android:topRightRadius="24dp"
        android:bottomRightRadius="4dp"
        android:bottomLeftRadius="4dp" />
</shape>
