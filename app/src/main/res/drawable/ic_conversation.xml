        android:strokeLineCap="round" android:pathData="M4,9.5L4,14.5" />
    <path android:strokeColor="@android:color/white" android:strokeWidth="2"
        android:strokeLineCap="round" android:pathData="M8,6.5L8,17.5" />
    <path android:strokeColor="@android:color/white" android:strokeWidth="2"
        android:strokeLineCap="round" android:pathData="M12,3.5L12,20.5" />
    <path android:strokeColor="@android:color/white" android:strokeWidth="2"
        android:strokeLineCap="round" android:pathData="M16,6.5L16,17.5" />
