<!-- The owner's Zone 1 field box (July 10 2026): a plain rectangular box with
     barely any corner curve (~4dp — square, not rounder than this), holding an
     input field whose label sits on its own line above it. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="1dp"
        android:color="?attr/colorOutline" />
    <corners android:radius="4dp" />
</shape>
