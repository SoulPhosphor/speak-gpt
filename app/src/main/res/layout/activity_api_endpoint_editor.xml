<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainerHigh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Upper-left double chevron = back / cancel. Backing out with unsaved
             edits triggers the discard-changes dialog (see the activity). -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_accent_icon_large_100"
            android:contentDescription="@string/go_back"
            android:src="@drawable/ic_back"
            android:tooltipText="@string/go_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Delete / Save action words, left-aligned at the top of the page.
                 Delete is hidden when adding a brand-new profile. The gap between
                 them is roughly four letters wide. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <TextView
                    android:id="@+id/btn_delete_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="8dp"
                    android:text="@string/btn_delete"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_save_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="40dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingVertical="8dp"
                    android:text="@string/btn_save"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/api_endpoint_friendly_name"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Model picker (tap to open dynamic model selector) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color"
                app:helperText="@string/api_endpoint_model_help"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_model"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:hint="@string/api_endpoint_model"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Provider (optional, free text). Sits directly under Model. -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutProvider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_provider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/api_endpoint_provider"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Connection timeout in seconds. Sits directly under Provider.
                 Consumed by ChatActivity.initAI() as the per-endpoint CONNECT
                 timeout; clamped to 5..300 on save. -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutTimeout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_timeout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/api_endpoint_connection_timeout"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Response time in seconds. Sits directly under Connection Timeout.
                 Consumed by ChatActivity.initAI() as the per-endpoint SOCKET
                 (response) timeout; floored at 45 on save, no maximum. -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutResponseTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_response_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/api_endpoint_response_time"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Temperature -->
            <TextView
                android:id="@+id/label_temperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="28dp"
                android:text="@string/label_temperature"
                android:textColor="@color/text_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_temperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:stepSize="1.0"
                android:value="7.0"
                android:valueFrom="0.0"
                android:valueTo="20.0" />

            <!-- Top P -->
            <TextView
                android:id="@+id/label_top_p"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="28dp"
                android:text="@string/label_top_p"
                android:textColor="@color/text_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_top_p"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:stepSize="1.0"
                android:value="10.0"
                android:valueFrom="0.0"
                android:valueTo="10.0" />

            <!-- Frequency penalty -->
            <TextView
                android:id="@+id/label_frequency_penalty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="28dp"
                android:text="@string/label_frequency_penalty"
                android:textColor="@color/text_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_frequency_penalty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:stepSize="1.0"
                android:value="0.0"
                android:valueFrom="-20.0"
                android:valueTo="20.0" />

            <!-- Presence penalty -->
            <TextView
                android:id="@+id/label_presence_penalty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="28dp"
                android:text="@string/label_presence_penalty"
                android:textColor="@color/text_title"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_presence_penalty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:stepSize="1.0"
                android:value="0.0"
                android:valueFrom="-20.0"
                android:valueTo="20.0" />

            <!-- Max tokens -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutMaxTokens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_max_tokens"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/label_max_tokens"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- End separator -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutEndSeparator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_end_separator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/label_end_separator"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Prefix -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutPrefix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_prefix"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/label_prefix"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout11"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_host"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/api_endpoint_host"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutChatEndpoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color"
                app:helperText="@string/api_endpoint_chat_endpoint_help"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_chat_endpoint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/api_endpoint_chat_endpoint"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayout12"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/api_endpoint_key_unchanged"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutAuth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="8dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color"
                app:helperText="@string/api_endpoint_auth_help"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_auth_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:hint="@string/api_endpoint_auth_mode"
                    android:singleLine="true"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
