<!-- Default Images (profile-images-plan.md ADDENDUM, Phase 6): a row each
     for Global Default and Personal Default, tapping into the gallery in
     assignment mode. Plan item 4 specifies only "a screen or row group
     where the user sets the Global Default and the Personal Default
     separately" - no leading preview thumbnail or Remove Picture row was
     ever approved for this screen; do not re-add either without asking. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        style="@style/Widget.App.ActionBar">

        <ImageButton
            android:id="@+id/btn_back"
            style="@style/Widget.App.ActionBar.BackButton" />

        <TextView
            android:id="@+id/activity_title"
            style="@style/Widget.App.ActionBar.Title"
            android:text="@string/row_default_images_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <LinearLayout
                android:id="@+id/row_global_default"
                style="@style/Widget.App.Row.WithSubtitle"
                android:layout_marginTop="16dp">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/row_global_default_title" />

                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:maxLines="3"
                        android:text="@string/row_global_default_subtitle" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/row_global_default_title" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_personal_default"
                style="@style/Widget.App.Row.WithSubtitle">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/row_personal_default_title" />

                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:maxLines="3"
                        android:text="@string/row_personal_default_subtitle" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/row_personal_default_title" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
