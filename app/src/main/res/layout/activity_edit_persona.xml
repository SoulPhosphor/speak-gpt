<!--
  Full-screen Companion editor (owner ruling, July 19 2026: the old pop-up
  became a full screen with the shared house header). The companion picture is
  a shaped, tappable preview at the top - tapping it opens the Profile Images
  gallery in companion-assignment mode; there is no Change/Remove button (owner:
  every gallery already holds all images, so changing = pick a different one).
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        style="@style/Widget.App.ActionBar">

        <ImageButton
            android:id="@+id/btn_back"
            style="@style/Widget.App.ActionBar.BackButton" />

        <TextView
            android:id="@+id/activity_title"
            style="@style/Widget.App.ActionBar.Title"
            android:text="@string/title_edit_companion" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottom_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Tappable companion picture. Shows the assigned image (shaped) or
                 a placeholder glyph; tap opens the gallery to pick another. -->
            <!-- Tappable, but no android:background: the shared ProfileImageBinder
                 resets the ImageView background to null every bind, so a ripple
                 set here would be dead. The picture itself is the affordance. -->
            <ImageView
                android:id="@+id/img_persona_avatar"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/edit_companion_image_desc"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Companion name (no hint line - none was ever owner-approved for
                 this field). text_field_label_error is a persistent inline
                 error (house rule: field errors set on the input itself, never
                 a toast/dialog) shown by EditPersonaActivity.save() when the
                 name is empty, in place of the old TextInputLayout.error. -->
            <TextView
                android:id="@+id/label_field_label"
                style="@style/Widget.App.Field.Label"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_friendly_name"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_persona_avatar" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_label"
                style="@style/Widget.App.Field.Box"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:singleLine="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/label_field_label" />

            <TextView
                android:id="@+id/text_field_label_error"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="24dp"
                android:textColor="?attr/colorError"
                android:textSize="13sp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/field_label" />

            <TextView
                android:id="@+id/label_field_prompt"
                style="@style/Widget.App.Field.Label"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_prompt_hint"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_field_label_error" />

            <TextView
                android:id="@+id/hint_field_prompt"
                style="@style/Widget.App.Field.Hint"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_prompt_help"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/label_field_prompt" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_prompt"
                style="@style/Widget.App.Field.Box"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:gravity="top|start"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="5"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/hint_field_prompt" />

            <TextView
                android:id="@+id/label_field_activation_prompt"
                style="@style/Widget.App.Field.Label"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_activation_hint"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/field_prompt" />

            <TextView
                android:id="@+id/hint_field_activation_prompt"
                style="@style/Widget.App.Field.Hint"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_activation_help"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/label_field_activation_prompt" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_activation_prompt"
                style="@style/Widget.App.Field.Box"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:singleLine="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/hint_field_activation_prompt" />

            <TextView
                android:id="@+id/label_field_core_lorebook"
                style="@style/Widget.App.Field.Label"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_core_lorebook_hint"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/field_activation_prompt" />

            <TextView
                android:id="@+id/hint_field_core_lorebook"
                style="@style/Widget.App.Field.Hint"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_core_lorebook_help"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/label_field_core_lorebook" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_core_lorebook"
                style="@style/Widget.App.Field.Box"
                android:layout_width="0dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:singleLine="true"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/hint_field_core_lorebook" />

            <TextView
                android:id="@+id/text_additional_lorebooks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                android:text="@string/persona_additional_lorebooks"
                android:textColor="@color/text_title"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/field_core_lorebook" />

            <LinearLayout
                android:id="@+id/additional_lorebooks_list"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="24dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_additional_lorebooks" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_lorebooks"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:text="@string/btn_add_lorebooks"
                app:icon="@drawable/ic_add"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/additional_lorebooks_list" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/checkbox_autoload_lorebooks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="24dp"
                android:text="@string/persona_autoload_lorebooks"
                android:textColor="@color/text_subtitle"
                android:textSize="14sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_add_lorebooks" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainerHigh"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/AppButton.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_save" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/AppButton.Destructive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_delete"
            android:visibility="gone" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
