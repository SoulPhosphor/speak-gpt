<!-- One Profile Images gallery tile (profile-images-plan.md, PROFILE IMAGES
     GALLERY / FILTERS / ACCESSIBILITY). One shared item layout applied to
     every tile - do not fork a second tile layout per state; every state
     (normal, Unused, Missing, In Use/locked in Selection Mode, Selected) is
     the same view with pieces shown or hidden. -->
<org.teslasoft.assistant.ui.views.SquareFrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tile_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:background="@drawable/bg_gallery_tile_placeholder"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/img_thumbnail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop" />

    <ImageView
        android:id="@+id/img_missing_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:contentDescription="@null"
        android:src="@drawable/ic_image_missing"
        android:tint="?attr/colorOnSurfaceVariant"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_status_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="4dp"
        android:background="@drawable/bg_gallery_tile_label"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:visibility="gone"
        tools:text="Unused" />

    <FrameLayout
        android:id="@+id/badge_container"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_gravity="top|end"
        android:layout_margin="4dp"
        android:visibility="gone">

        <View
            android:id="@+id/badge_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gallery_selected_badge" />

        <ImageView
            android:id="@+id/badge_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:contentDescription="@null" />
    </FrameLayout>
</org.teslasoft.assistant.ui.views.SquareFrameLayout>
