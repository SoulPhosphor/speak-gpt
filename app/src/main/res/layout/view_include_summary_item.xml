<?xml version="1.0" encoding="utf-8"?>
<!--
  One line inside an expanded "Includes" record: the file's type icon, its
  name, and roughly what it weighed when the message was sent. Each type has
  its own icon so a later attachment kind (an image, say) is identifiable at a
  glance without reading the name.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="28dp"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/summary_item_icon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="6dp"
        android:contentDescription="@string/include_icon_desc"
        android:src="@drawable/ic_doc_text"
        android:tint="?attr/colorPrimary" />

    <TextView
        android:id="@+id/summary_item_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="middle"
        android:textColor="@color/text"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/summary_item_weight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/text_subtitle"
        android:textSize="11sp" />
</LinearLayout>
