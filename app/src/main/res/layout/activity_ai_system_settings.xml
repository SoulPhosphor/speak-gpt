<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainerHigh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_accent_icon_large_100"
            android:contentDescription="@string/go_back"
            android:src="@drawable/ic_back"
            android:tooltipText="@string/go_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back" />

        <TextView
            android:id="@+id/activity_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_ai_system_settings"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Owner-approved mindfulness hint (§11 Revision 5): covers both the
                 system prompt and the model rules, which both ride every turn. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/ai_system_settings_hint"
                android:textColor="@color/text_subtitle"
                android:textSize="14sp" />

            <!-- API chat endpoint profiles: moved here off the main Settings
                 screen (July 2026). Opens the profiles list; the subtitle shows
                 the profile currently in use. -->
            <LinearLayout
                android:id="@+id/row_api_profiles"
                style="@style/Widget.App.Row.WithSubtitle"
                android:layout_marginTop="24dp">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/title_api_endpoint_profiles" />

                    <TextView
                        android:id="@+id/text_api_profiles_subtitle"
                        style="@style/Widget.App.Row.Subtitle" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/title_api_endpoint_profiles" />
            </LinearLayout>

            <!-- System prompts: opens the user's library of saved system prompts
                 (SystemPromptsListActivity). The subtitle mirrors whichever
                 prompt is currently active for the chat, or "None". -->
            <LinearLayout
                android:id="@+id/row_system_prompt"
                style="@style/Widget.App.Row.WithSubtitle"
                android:layout_marginTop="8dp">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/title_system_prompts" />

                    <TextView
                        android:id="@+id/text_system_prompt_subtitle"
                        style="@style/Widget.App.Row.Subtitle"
                        android:text="@string/system_prompt_none" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/title_system_prompts" />
            </LinearLayout>

            <!-- Model Specific Rules: opens the rules browser (Stage 4 slice 4). -->
            <LinearLayout
                android:id="@+id/row_model_rules"
                style="@style/Widget.App.Row.WithSubtitle">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/row_model_rules_title" />

                    <!-- This description is long; the shared subtitle style's
                         single-line ellipsis would cut it off, so it keeps its
                         own unbounded wrapping instead of the style's default. -->
                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:ellipsize="none"
                        android:maxLines="6"
                        android:text="@string/row_model_rules_subtitle" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/row_model_rules_title" />
            </LinearLayout>

            <!-- Global default for whether matching model rules apply. Per-chat
                 override lives in Quick Settings ("Apply Model Rules"). -->
            <LinearLayout style="@style/Widget.App.Row.Toggle">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/label_auto_apply_model_rules_title" />

                    <!-- This description is long; the shared subtitle style's
                         single-line ellipsis would cut it off, so it keeps its
                         own unbounded wrapping instead of the style's default. -->
                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:ellipsize="none"
                        android:maxLines="6"
                        android:text="@string/label_auto_apply_model_rules_desc" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_auto_apply_model_rules"
                    style="@style/Widget.App.Row.Switch" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
