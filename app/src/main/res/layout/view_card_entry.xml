<!-- One Zone 2 card entry row (roleplay cards only — deliberately NOT the
     shared view_memory_row the Memories browser uses, so the two screens keep
     independent control of their look; owner ruling, July 10 2026). No box, no
     leading indent: name on top, description under it, then the entry's tags.
     Name / description / tags are all chat-message size (16sp) so the OS
     font-size setting scales them for accessibility later. Each tag is a
     tappable outlined box that opens the tag's cross-card page directly. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/entry_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:paddingVertical="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/entry_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="?attr/colorPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Promoted-NPC marker, used by the world card only (spec §8a); other
             cards leave it hidden. -->
        <TextView
            android:id="@+id/entry_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/memory_badge_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="?attr/colorOnTertiaryContainer"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/entry_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="@color/text_subtitle"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Each tag is an outlined ~4dp box (no fill), tappable → its tag page.
         chipSpacingHorizontal gives roughly three letters of gap between tags
         so they never sit on top of each other (owner ask, July 10 2026). -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/entry_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:visibility="gone"
        app:chipSpacingHorizontal="20dp"
        app:chipSpacingVertical="6dp" />
</LinearLayout>
