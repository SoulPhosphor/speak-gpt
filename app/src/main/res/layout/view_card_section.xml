<!-- One Zone 2 card section (spec §6): title, its entries, and the
     owner-approved "Add Entry" button. Inflated per section by the card
     screens; entry rows (view_memory_row) are added into section_entries. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/section_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:textColor="?attr/colorPrimary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/section_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"
        android:text="@string/card_no_entries"
        android:textColor="@color/text_subtitle"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/section_entries"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_add_entry"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/card_btn_add_entry"
        app:icon="@drawable/ic_add" />
</LinearLayout>
