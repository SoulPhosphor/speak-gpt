<!-- Manager-mode row for the activation prompt library (owner request, July
     18 2026): browsing/editing uses a plain title-only row with a chevron —
     no prompt-text preview, just the label the user gave it. The separate
     always-visible edit button is folded into the row's own tap target
     (long-press still opens the editor, same as before). Pick mode
     (choosing an activation prompt for a chat, from Quick Settings) keeps
     the separate "checked tile" layout in view_activation_prompt_item.xml,
     unchanged. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ui"
    style="@style/Widget.App.Row.TitleOnly"
    android:paddingHorizontal="20dp">

    <LinearLayout style="@style/Widget.App.Row.TextColumn">

        <TextView
            android:id="@+id/activation_label"
            style="@style/Widget.App.Row.Title"
            android:ellipsize="end"
            android:lines="1"
            android:text="Activation prompt" />
    </LinearLayout>

    <ImageView
        android:id="@+id/activation_prompt_chevron"
        style="@style/Widget.App.Row.Chevron"
        android:contentDescription="@string/btn_edit_activation_prompt" />
</LinearLayout>
