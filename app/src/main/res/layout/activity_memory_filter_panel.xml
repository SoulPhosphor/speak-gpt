<!-- Memory Filters panel (owner ruling, July 8 2026). Slides in from the right;
     header holds the title + close-X; body is a scrolling list of five filter
     sections (Sort, Scope, Type, Source, Tags — Status left the panel the
     same evening: the browser's Memories | Pending toggle owns the status
     split) in Title Case with each selection rendered as a pill (10dp
     corners) with a tiny × to remove. Category rows are populated in code so
     options can be added over time without a layout rewrite. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        style="@style/Widget.App.ActionBar">

        <TextView
            android:id="@+id/activity_title"
            style="@style/Widget.App.ActionBar.Title.LeftAligned"
            android:text="@string/title_memory_filters" />

        <ImageButton
            android:id="@+id/btn_close"
            style="@style/Widget.App.ActionBar.CloseButton"
            android:contentDescription="@string/mem_filter_close"
            android:tooltipText="@string/mem_filter_close" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:id="@+id/sections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp">

            <!-- Filter sections are appended here from MemoryFilterPanelActivity;
                 the Reset Filters row is appended last, once, at the bottom. -->
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
