<?xml version="1.0" encoding="utf-8"?>
<!--
  The "Includes" record inside a sent chat message: a small box under the
  user's name that opens like an accordion to list what was attached to THAT
  message (owner design, July 24 2026).

  This is a record of the past, not a control: it shows what went with this
  turn, which is why it stays after the attachment has been condensed or
  removed. The live strip above the message box shows the present.

  When everything attached has been reduced to a bookmark, the leading icon
  becomes the bookmark-with-check glyph — the owner's "artifact" marker.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/include_summary"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">

    <LinearLayout
        android:id="@+id/include_summary_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:minHeight="32dp"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp">

        <ImageView
            android:id="@+id/include_summary_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="@string/include_icon_desc"
            android:src="@drawable/ic_file"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/include_summary_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/include_label"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/include_summary_chevron"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/include_expand_desc"
            android:src="@drawable/ic_chevron_down"
            android:tint="?attr/colorPrimary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/include_summary_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />
</LinearLayout>
