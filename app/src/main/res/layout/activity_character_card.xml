<!-- The two-zone character card (roleplay_cards_and_tags_spec §6a/§6b):
     serves the user RP character AND the NPC party member — the party member
     shows two extra Zone 1 fields (Speech Style, Status). Zone labels and the
     word-count/warning texts are the owner's approved words (spec §8a). -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainerHigh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_accent_icon_large_100"
            android:contentDescription="@string/go_back"
            android:src="@drawable/ic_back"
            android:tooltipText="@string/go_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back" />

        <TextView
            android:id="@+id/activity_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/card_title_character"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Zone 1 — always visibly labeled (spec §1/§8a). Each field is a
                 label on its own line, the box immediately under it, then one
                 empty half-line before the next field (owner ruling, July 10
                 2026). No floating-hint boxes. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/card_zone1_title"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/card_zone1_subtext"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                style="@style/Widget.App.Field.Label"
                android:layout_marginTop="16dp"
                android:text="@string/mem_pers_field_name" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_card_name"
                style="@style/Widget.App.Field.Box"
                android:inputType="textCapSentences"
                android:singleLine="true" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <TextView
                style="@style/Widget.App.Field.Label"
                android:text="@string/card_field_species" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_card_species"
                style="@style/Widget.App.Field.Box"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <TextView
                style="@style/Widget.App.Field.Label"
                android:text="@string/card_field_class" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_card_class"
                style="@style/Widget.App.Field.Box"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <TextView
                style="@style/Widget.App.Field.Label"
                android:text="@string/card_field_core_personality" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_card_core_personality"
                style="@style/Widget.App.Field.Box"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <TextView
                style="@style/Widget.App.Field.Label"
                android:text="@string/card_field_physical_description" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_card_physical_description"
                style="@style/Widget.App.Field.Box"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <TextView
                style="@style/Widget.App.Field.Label"
                android:text="@string/card_field_goals_drives" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/field_card_goals_drives"
                style="@style/Widget.App.Field.Box"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- NPC-only Zone 1 field (spec §6b); GONE for the user card. The
                 container carries the id the activity toggles. -->
            <LinearLayout
                android:id="@+id/layout_card_speech_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    style="@style/Widget.App.Field.Label"
                    android:text="@string/card_field_speech_style" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_card_speech_style"
                    style="@style/Widget.App.Field.Box"
                    android:gravity="top"
                    android:inputType="textMultiLine|textCapSentences" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_card_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/card_field_status"
                    android:textColor="@color/text_title"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_card_status"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/card_status_alive" />
            </LinearLayout>

            <!-- Word count under the Zone 1 box, right-aligned; warning to its
                 left. 300 words: warning appears. 500: count turns red on its
                 neutral pill (spec §8a). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_card_warning"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_subtitle"
                    android:textSize="13sp"
                    android:visibility="invisible" />

                <TextView
                    android:id="@+id/text_card_word_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_count"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/text_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_card_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/btn_save" />

            <!-- One browser, many doors (§8): the RP character's memories.
                 GONE for party members — NPCs aren't a memory scope. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_card_memories"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:icon="@drawable/ic_storage"
                android:text="@string/title_memories" />

            <!-- Zone 2 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="28dp"
                android:text="@string/card_zone2_title"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:text="@string/card_zone2_subtext"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_save_first"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:text="@string/card_save_first"
                android:textColor="@color/text_subtitle"
                android:textSize="14sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/sections_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
