<!-- Roleplay Characters row (owner ruling, July 21 2026): the shared house row
     style with a leading profile picture - Image + Title only (name), no
     subtitle. The leading picture follows the user-side cascade (own picture ->
     Default Personal Avatar -> person icon), bound in ProfileImageRowAdapter.
     Tapping the row opens the character card; the trailing chevron opens the
     row's action menu (edit / archive / memories / delete). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ui"
    style="@style/Widget.App.Row.TitleOnly"
    android:paddingHorizontal="20dp">

    <ImageView
        android:id="@+id/persona_avatar"
        style="@style/Widget.App.Row.ProfileImage"
        android:contentDescription="@string/profile_image_default_personal_avatar_desc" />

    <LinearLayout style="@style/Widget.App.Row.TextColumn">

        <TextView
            android:id="@+id/persona_label"
            style="@style/Widget.App.Row.Title"
            android:ellipsize="end"
            android:lines="1"
            android:text="Character" />
    </LinearLayout>

    <ImageView
        android:id="@+id/persona_menu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/mem_row_more_options"
        android:padding="12dp"
        android:scaleType="center"
        android:src="@drawable/ic_chevron_right"
        android:tint="?attr/appRowSubtitleColor" />
</LinearLayout>
