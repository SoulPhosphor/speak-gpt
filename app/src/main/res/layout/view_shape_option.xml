<!-- One Default Shape choice (Flower / Circle / Square), with a small
     visual preview (profile-images-plan.md: "Each choice includes a small
     visual preview"). One shared item layout, inflated once per shape and
     bound in code - not three hand-copied blocks. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/option_root"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingVertical="8dp">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <ImageView
            android:id="@+id/option_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@null" />

        <FrameLayout
            android:id="@+id/option_badge"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gallery_selected_badge" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_done"
                android:tint="@android:color/white" />
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/option_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text"
        android:textSize="13sp" />
</LinearLayout>
