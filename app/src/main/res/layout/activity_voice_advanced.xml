<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/accent_100"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_accent_icon_large_100"
            android:contentDescription="@string/go_back"
            android:src="@drawable/ic_back"
            android:tooltipText="@string/go_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back" />

        <TextView
            android:id="@+id/activity_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_voice_advanced"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/adv_intro"
                android:textColor="@color/text_subtitle"
                android:textSize="14sp" />

            <!-- ============ Voice detection ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/adv_section_vad"
                android:textColor="@color/accent_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:text="@string/adv_section_vad_caption"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_energy_gate_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_energy_gate_desc"
                        android:textColor="@color/text_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_energy_gate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/label_min_rms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_min_rms_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_min_rms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="50"
                android:valueFrom="50"
                android:valueTo="2000" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_min_rms_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_floor_factor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_floor_factor_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_floor_factor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="0.1"
                android:valueFrom="1.0"
                android:valueTo="6.0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_floor_factor_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_ceiling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_ceiling_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_ceiling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="100"
                android:valueFrom="600"
                android:valueTo="4000" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_ceiling_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_min_speech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_min_speech_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_min_speech"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="50"
                android:valueFrom="0"
                android:valueTo="1000" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_min_speech_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_hysteresis_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_hysteresis_desc"
                        android:textColor="@color/text_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_hysteresis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/label_hyst_exit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_hyst_exit_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_hyst_exit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="5"
                android:valueFrom="20"
                android:valueTo="95" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_hyst_exit_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_hangover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_hangover_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_hangover"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="50"
                android:valueFrom="0"
                android:valueTo="1000" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_hangover_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_silero_threshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_silero_threshold_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_silero_threshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="5"
                android:valueFrom="5"
                android:valueTo="95" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_silero_threshold_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_vad"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/adv_reset_vad" />

            <!-- ============ Whisper decoding ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="28dp"
                android:text="@string/adv_section_whisper"
                android:textColor="@color/accent_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:text="@string/adv_section_whisper_caption"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/adv_decoder_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/radio_decoder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radio_decoder_beam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adv_decoder_beam"
                    android:textColor="@color/text"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/radio_decoder_greedy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adv_decoder_greedy"
                    android:textColor="@color/text"
                    android:textSize="15sp" />
            </RadioGroup>

            <TextView
                android:id="@+id/label_beam_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/adv_beam_size_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_beam_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="1"
                android:valueFrom="1"
                android:valueTo="8" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_beam_size_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_temperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_temperature_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_temperature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="0.05"
                android:valueFrom="0"
                android:valueTo="1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_temperature_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_suppress_blank_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_suppress_blank_desc"
                        android:textColor="@color/text_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_suppress_blank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_single_segment_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_single_segment_desc"
                        android:textColor="@color/text_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_single_segment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_initial_prompt_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_initial_prompt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColorHint="@color/text_hint"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeColor="@drawable/box_stroke_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/field_initial_prompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:hint="@string/adv_initial_prompt_hint"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:textColorHint="@color/text_hint" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_initial_prompt_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_prev_context_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_prev_context_desc"
                        android:textColor="@color/text_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_prev_context"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_cleanup_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_cleanup_desc"
                        android:textColor="@color/text_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_cleanup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_whisper_debug_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/adv_whisper_debug_desc"
                        android:textColor="@color/text_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_whisper_debug"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- ============ TTS delivery ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="28dp"
                android:text="@string/adv_section_tts"
                android:textColor="@color/accent_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:text="@string/adv_section_tts_caption"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_tts_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:text="@string/adv_tts_rate_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_tts_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="0.1"
                android:valueFrom="0.5"
                android:valueTo="2.5" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_tts_rate_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/label_tts_pitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="20dp"
                android:text="@string/adv_tts_pitch_title"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <com.google.android.material.slider.Slider
                android:id="@+id/slider_tts_pitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stepSize="0.1"
                android:valueFrom="0.5"
                android:valueTo="2.0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/adv_tts_pitch_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <!-- ============ Diagnostics ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="28dp"
                android:text="@string/adv_section_diag"
                android:textColor="@color/accent_900"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="4dp"
                android:text="@string/adv_section_diag_caption"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/tile_vad_log_energy_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_log_energy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/tile_vad_log_webrtc_title"
                        android:textColor="@color/text"
                        android:textSize="16sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_log_webrtc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_open_event_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/adv_open_event_log" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
