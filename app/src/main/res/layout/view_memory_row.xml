<!-- Memory row (owner ruling, July 8 2026):
     [ leading identity icon ][ title (bold, larger) / tags (small, dot-joined,
       no hashtags) / content (normal) ][ edit-square trailing action ].
     The icon spans the full row height and its resource is picked per memory
     by the browser from the scope enum (see ic_mem_* drawables). The trailing
     button is only shown for rows that have per-row actions. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ui"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="8dp"
        android:background="@drawable/btn_accent_tonal_selector_v3"
        android:backgroundTint="?attr/colorSecondaryContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Leading identity icon. Centred vertically; sized so it visually
             matches the row height across the title/tags/content lines. -->
        <ImageView
            android:id="@+id/row_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="14dp"
            android:contentDescription="@string/mem_row_icon"
            android:src="@drawable/ic_mem_public"
            android:visibility="gone"
            app:tint="?attr/colorPrimary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/row_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="@string/label_memory"
            android:textColor="?attr/colorPrimary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/row_badge"
            app:layout_constraintStart_toEndOf="@+id/row_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/row_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/memory_badge_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="?attr/colorOnTertiaryContainer"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@+id/btn_row_action"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Tag list: small, dot-joined, no hashtags. The browser builds this
             already-formatted (Communication · Technical Help · Tone). -->
        <TextView
            android:id="@+id/row_tags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_subtitle"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@+id/btn_row_action"
            app:layout_constraintStart_toStartOf="@+id/row_title"
            app:layout_constraintTop_toBottomOf="@+id/row_title" />

        <!-- Memory content line — normal weight, 13sp. -->
        <TextView
            android:id="@+id/row_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="12dp"
            android:ellipsize="end"
            android:maxLines="3"
            android:textColor="@color/text_subtitle"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@+id/btn_row_action"
            app:layout_constraintStart_toStartOf="@+id/row_title"
            app:layout_constraintTop_toBottomOf="@+id/row_tags" />

        <!-- Persistent inline note (owner design, July 9 2026): e.g. "Needs
             roleplay target." on an untargeted roleplay draft. Never a
             vanishing message. -->
        <TextView
            android:id="@+id/row_note"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="?attr/colorPrimary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toStartOf="@+id/btn_row_action"
            app:layout_constraintStart_toStartOf="@+id/row_title"
            app:layout_constraintTop_toBottomOf="@+id/row_subtitle" />

        <!-- Pending action words (owner design, July 8 2026 evening): across
             the bottom of every PENDING memory row, larger than the normal
             row text and bold so they're easy to see. Add to Card appears on
             roleplay memories only. Hidden everywhere outside Pending view. -->
        <LinearLayout
            android:id="@+id/row_pending_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/row_title"
            app:layout_constraintTop_toBottomOf="@+id/row_note">

            <TextView
                android:id="@+id/action_accept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp"
                android:paddingEnd="18dp"
                android:text="@string/mem_pending_accept"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/action_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp"
                android:paddingEnd="18dp"
                android:text="@string/mem_pending_delete"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/action_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp"
                android:paddingEnd="18dp"
                android:text="@string/mem_pending_edit"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/action_add_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="6dp"
                android:text="@string/mem_pending_add_card"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Trailing action: edit-square (replaces the old cog per owner ruling,
             July 8 2026). Only visible for rows that have a per-row menu. -->
        <ImageButton
            android:id="@+id/btn_row_action"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/btn_accent_tonal_selector_v7"
            android:contentDescription="@string/mem_row_edit"
            android:src="@drawable/ic_edit_square"
            android:tooltipText="@string/mem_row_edit"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_edit_square" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
