<!-- Companion row (owner ruling, July 19 2026 evening): plain Image + Title +
     Chevron, the same shared style family as the System Prompts manager-mode
     row (view_system_prompt_item_row.xml) - no highlight, no color inversion.
     "Currently active" is not a concept this row shows at all anymore; that
     lives in Quick Settings and the last-used companion logic. Tapping the
     whole row opens that Companion's edit screen (PersonasListActivity routes
     the click to openEditor); there is no separate select action here. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ui"
    style="@style/Widget.App.Row.TitleOnly"
    android:paddingHorizontal="20dp">

    <ImageView
        android:id="@+id/persona_avatar"
        style="@style/Widget.App.Row.ProfileImage"
        android:contentDescription="@string/profile_image_companion_avatar_desc" />

    <LinearLayout style="@style/Widget.App.Row.TextColumn">

        <TextView
            android:id="@+id/persona_label"
            style="@style/Widget.App.Row.Title"
            android:ellipsize="end"
            android:lines="1"
            android:text="Persona" />
    </LinearLayout>

    <ImageView
        style="@style/Widget.App.Row.Chevron"
        android:contentDescription="@string/btn_edit_persona" />
</LinearLayout>
