<?xml version="1.0" encoding="utf-8"?>
<!--
  Numeric entry for the Framing screen's Fine Rotation dialog. Hosted in a
  MaterialAlertDialog (App.MaterialAlertDialog theme), which supplies the
  title, the Reset to 0° / Cancel / Apply actions, and all dialog theming.
  The TextInputLayout carries the inline "Enter a value between −45° and 45°."
  error when validation fails.
-->
<com.google.android.material.textfield.TextInputLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/fine_rotation_input_layout"
    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="24dp"
    android:hint="@string/fine_rotation_hint">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/fine_rotation_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal|numberSigned"
        android:maxLines="1" />

</com.google.android.material.textfield.TextInputLayout>
