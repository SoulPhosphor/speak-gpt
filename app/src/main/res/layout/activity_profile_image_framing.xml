<?xml version="1.0" encoding="utf-8"?>
<!--
  Framing editor (profile-images-plan.md, EXACT FRAMING CONTROL ORDER). This
  is a full-bleed photo editor surface with its own dark chrome (like the
  reference screenshot): the photo sits behind a dimmed scrim drawn by
  FramingView, with a centred square crop window. Control order, top to
  bottom: Flip/Rotate (top-right), the fine-angle readout, the tick dial,
  then the Cancel / Framing / Done bottom bar.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/framing_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <org.teslasoft.assistant.ui.views.FramingView
        android:id="@+id/framing_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top-right overlay controls: Flip then Rotate. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:orientation="horizontal"
        android:padding="8dp">

        <ImageButton
            android:id="@+id/btn_flip"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/framing_flip"
            android:src="@drawable/ic_flip" />

        <ImageButton
            android:id="@+id/btn_rotate"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/framing_rotate"
            android:src="@drawable/ic_rotate" />
    </LinearLayout>

    <!-- Bottom stack: readout, dial, then the action bar. -->
    <LinearLayout
        android:id="@+id/framing_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingHorizontal="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/fine_rotation_readout"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="72dp"
            android:paddingHorizontal="16dp"
            android:textColor="@android:color/white"
            android:textSize="18sp" />

        <org.teslasoft.assistant.ui.views.RotationDialView
            android:id="@+id/rotation_dial"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_cancel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/framing_cancel"
                android:src="@drawable/ic_close" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/framing_title"
                android:textColor="@android:color/white"
                android:textSize="18sp" />

            <ImageButton
                android:id="@+id/btn_done"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/framing_done"
                android:enabled="false"
                android:src="@drawable/ic_done" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
