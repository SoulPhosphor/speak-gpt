<!-- Memory Backup & Restore (Database Health & Backups). Section order is
     owner-directed and EXACT (July 22 2026): 1. Database Health, 2. Backup
     Status, 3. Recovery Backup, 4. Human-Readable Chat Backup, 5. Portable
     Data Copy, 6. Automatic Backups, 7. Reset. Do not reorder. The manual and
     automatic backup locations are separate. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainerHigh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_accent_icon_large_100"
            android:contentDescription="@string/go_back"
            android:src="@drawable/ic_back"
            android:tooltipText="@string/go_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back" />

        <TextView
            android:id="@+id/activity_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_memory_backup_restore"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- ============ 1. Database Health ============ -->
            <!-- Section heading + hint styles: Widget.App.Section.Title/.Hint
                 (see values/themes.xml + ui-style-guide.md). The hint always
                 comes directly under the title and before the button it
                 explains - never after the button. -->
            <TextView
                style="@style/Widget.App.Section.Title"
                android:text="@string/backup_db_health_section" />

            <TextView
                style="@style/Widget.App.Section.Hint"
                android:text="@string/backup_check_integrity_hint" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_check_integrity"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/backup_check_integrity" />

            <!-- §15.9 verbatim in-progress line: visible only while the check
                 runs, then replaced by the per-database result lines below. -->
            <TextView
                android:id="@+id/text_check_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:text="@string/health_check_progress"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_result_memory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_result_lorebook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_result_userimage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <!-- ============ 2. Backup Status ============ -->
            <TextView
                style="@style/Widget.App.Section.Title"
                android:text="@string/backup_status_section" />

            <TextView
                android:id="@+id/text_status_memory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_status_lorebooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_status_chats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_status_userimage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <!-- ============ 3. Recovery Backup (manual) ============ -->
            <TextView
                style="@style/Widget.App.Section.Title"
                android:text="@string/backup_create_section" />

            <TextView
                style="@style/Widget.App.Section.Hint"
                android:text="@string/backup_create_hint" />

            <!-- Recovery Type summaries, same font as the section hint
                 (Widget.App.Section.Hint), text set in Kotlin from
                 recovery_type_summary_format + the SAME title/desc strings
                 the Recovery Backup screen's choice panel uses, so these can
                 never drift out of sync with the actual choice (owner
                 ruling, July 22 2026). -->
            <TextView
                android:id="@+id/text_recovery_type_protected_summary"
                style="@style/Widget.App.Section.Hint" />

            <TextView
                android:id="@+id/text_recovery_type_unencrypted_summary"
                style="@style/Widget.App.Section.Hint" />

            <!-- Recovery Type dropdown: Widget.App.Dropdown.* (owner ruling,
                 July 22 2026), same pattern as the Human-Readable Chat Backup
                 fields below. Picking a type here skips the separate choice
                 screen the "Create Recovery Backup" button used to open —
                 that screen now goes straight to the picked type's next step.
                 The selection is remembered across visits
                 (RecoveryBackupState.getLastRecoveryProtected/
                 setLastRecoveryProtected), the same way Backup Style and
                 Format below are. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.App.Dropdown.Label"
                    android:text="@string/recovery_type_label" />

                <TextView
                    android:id="@+id/btn_recovery_type"
                    style="@style/Widget.App.Dropdown.Value"
                    android:layout_weight="1" />
            </LinearLayout>

            <!-- Recovery Backup: one tap opens the system Save dialog directly
                 (owner directive, July 24 2026 — supersedes the earlier
                 multi-screen build/result flow). The location line shows
                 where the last one landed, same breadcrumb format as
                 Automatic Backup Location below; the spinner + status row
                 underneath the button carries Preparing/Saving/Successful/
                 failure text inline, matching the Human-Readable Chat Backup
                 and Automatic Backups sections — no screen change. -->
            <TextView
                android:id="@+id/text_recovery_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:textColor="@color/text"
                android:textIsSelectable="true"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_recovery"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/recovery_create" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/spinner_recovery_status"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="10dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorSize="18dp"
                    app:trackThickness="2dp"
                    style="@style/Widget.Material3.CircularProgressIndicator" />

                <TextView
                    android:id="@+id/text_recovery_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text"
                    android:textIsSelectable="true"
                    android:textSize="13sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ============ 4. Human-Readable Chat Backup ============ -->
            <TextView
                style="@style/Widget.App.Section.Title"
                android:text="@string/backup_readable_section" />

            <TextView
                style="@style/Widget.App.Section.Hint"
                android:text="@string/backup_readable_desc" />

            <!-- Multiple-choice fields: standard same-line label + dropdown,
                 Widget.App.Dropdown.* (owner ruling, July 22 2026). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.App.Dropdown.Label"
                    android:text="@string/backup_readable_scope_label" />

                <TextView
                    android:id="@+id/btn_readable_scope"
                    style="@style/Widget.App.Dropdown.Value"
                    android:layout_weight="1"
                    android:text="@string/backup_readable_scope_all" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.App.Dropdown.Label"
                    android:text="@string/backup_readable_format_label" />

                <TextView
                    android:id="@+id/btn_readable_format"
                    style="@style/Widget.App.Dropdown.Value"
                    android:layout_weight="1"
                    android:text="@string/backup_readable_format_text" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_readable_create"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_readable_create" />

            <!-- Persistent inline status: preparing / saved / failed / "No new
                 or updated chats." — stays until replaced. Never a toast. -->
            <TextView
                android:id="@+id/text_readable_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <!-- ============ 5. Portable Data Copy ============ -->
            <TextView
                style="@style/Widget.App.Section.Title"
                android:text="@string/backup_portable_section" />

            <!-- Two explanatory paragraphs, both directly under the title and
                 before either button (owner correction, July 22 2026): the
                 privacy warning used to sit below the buttons and the status
                 line, reading as if it described something else entirely. -->
            <TextView
                style="@style/Widget.App.Section.Hint"
                android:text="@string/backup_portable_desc" />

            <TextView
                style="@style/Widget.App.Section.Hint"
                android:text="@string/backup_portable_warning" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_portable_export"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/backup_portable_export" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_portable_import"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_portable_import" />

            <!-- Persistent inline status for export/import results (replaces
                 the removed toasts). Stays until replaced. -->
            <TextView
                android:id="@+id/text_portable_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <!-- ============ 6. Automatic Backups ============ -->
            <!-- The approved portable automatic WRITER (the piece that would
                 actually run a backup on a schedule) is NOT built. This
                 section says so honestly. The toggle and frequency dropdown
                 below are restored/visible (owner ruling, July 22 2026) and
                 persist the user's choice for when that writer exists; the
                 location chooser stays for the same reason it always did.
                 Order is fixed: toggle, dropdown, location, button. -->
            <TextView
                style="@style/Widget.App.Section.Title"
                android:text="@string/backup_auto_section" />

            <TextView
                style="@style/Widget.App.Section.Hint"
                android:text="@string/backup_auto_hint" />

            <!-- Toggle row: Widget.App.Row.Toggle/.TextColumn/.Title/.Subtitle/
                 .Switch (established house style — see ui-style-guide.md;
                 first used by "Automatically Apply Model Rules" on AI System
                 Settings). A toggle row always carries a subtitle. -->
            <LinearLayout style="@style/Widget.App.Row.Toggle">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/backup_auto_enable" />

                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:text="@string/backup_auto_enable_subtitle" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_auto_backup"
                    style="@style/Widget.App.Row.Switch" />
            </LinearLayout>

            <!-- Frequency dropdown: Widget.App.Dropdown.* (owner ruling, July
                 22 2026), same pattern as the other dropdowns on this screen;
                 selection persists (RecoveryBackupState.getAutoFrequency/
                 setAutoFrequency). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/Widget.App.Dropdown.Label"
                    android:text="@string/backup_auto_frequency_label" />

                <TextView
                    android:id="@+id/btn_auto_frequency"
                    style="@style/Widget.App.Dropdown.Value"
                    android:layout_weight="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_auto_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:textColor="@color/text"
                android:textIsSelectable="true"
                android:textSize="15sp" />

            <!-- Automatic-set status: Last Automatic Backup / File Size / Next
                 Automatic Backup Due (or the paused/never state). Records
                 surfaced honestly; the per-type rows in Backup Status show
                 each artifact's own result. While a pass is actively running
                 (spinner_auto_status visible) this text instead reads
                 backup_auto_status_creating - the spinner and text sit in one
                 row so both toggle together. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/spinner_auto_status"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="10dp"
                    android:indeterminate="true"
                    android:visibility="gone"
                    app:indicatorSize="18dp"
                    app:trackThickness="2dp"
                    style="@style/Widget.Material3.CircularProgressIndicator" />

                <TextView
                    android:id="@+id/text_auto_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text"
                    android:textIsSelectable="true"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_change_auto_location"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_auto_change_location" />

            <!-- ============ 7. Reset (destructive; bottom, unchanged) ============ -->
            <TextView
                style="@style/Widget.App.Section.Title"
                android:text="@string/memory_controls_section_reset" />

            <TextView
                style="@style/Widget.App.Section.Hint"
                android:text="@string/memory_controls_reset_hint" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_memory_reset"
                style="@style/AppButton.Destructive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/memory_controls_reset" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
