<!-- Memory Backup & Restore (Database Health & Backups). Section order is
     owner-directed and EXACT (July 22 2026): 1. Database Health, 2. Backup
     Status, 3. Recovery Backup, 4. Human-Readable Chat Backup, 5. Portable
     Data Copy, 6. Automatic Backups, 7. Reset. Do not reorder. The manual and
     automatic backup locations are separate. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainerHigh"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/btn_accent_icon_large_100"
            android:contentDescription="@string/go_back"
            android:src="@drawable/ic_back"
            android:tooltipText="@string/go_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_back" />

        <TextView
            android:id="@+id/activity_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_memory_backup_restore"
            android:textColor="@color/text_title"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- ============ 1. Database Health ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/backup_db_health_section"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_check_integrity"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/backup_check_integrity" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/backup_check_integrity_hint"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_result_memory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_result_lorebook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_result_userimage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <!-- ============ 2. Backup Status ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/backup_status_section"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_status_memory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_status_lorebooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_status_chats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_status_userimage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <!-- ============ 3. Recovery Backup (manual) ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/backup_create_section"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Portable recovery (format v2) entry — the owner-approved
                 Create Recovery Backup flow, now the ONLY manual backup control.
                 The installation-bound v1 controls (text_manual_location,
                 btn_change_manual_location, btn_create_backup) are HIDDEN (owner
                 ruling, July 22 2026, correction 1): kept in the tree so the
                 activity's existing bindings/logic still resolve, but never
                 shown. Do not un-hide without the owner's word. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_recovery"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/recovery_create" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/backup_create_hint"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_manual_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:textColor="@color/text"
                android:textIsSelectable="true"
                android:textSize="15sp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_change_manual_location"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_change_location"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_backup"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_create"
                android:visibility="gone" />

            <!-- ============ 4. Human-Readable Chat Backup ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/backup_readable_section"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/backup_readable_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_readable_scope"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/backup_readable_scope_all" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_readable_format"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_readable_format_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_readable_create"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_readable_create" />

            <!-- Persistent inline status: preparing / saved / failed / "No new
                 or updated chats." — stays until replaced. Never a toast. -->
            <TextView
                android:id="@+id/text_readable_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <!-- ============ 5. Portable Data Copy ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/backup_portable_section"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/backup_portable_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_portable_export"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/backup_portable_export" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_portable_import"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_portable_import" />

            <!-- Persistent inline status for export/import results (replaces
                 the removed toasts). Stays until replaced. -->
            <TextView
                android:id="@+id/text_portable_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/backup_portable_warning"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <!-- ============ 6. Automatic Backups ============ -->
            <!-- The portable automatic system (July 22 2026): due-check at
                 app open, protected packages only, user-chosen folder
                 required. The switch is real and gated — it cannot turn on
                 without a folder and a confirmed Recovery Code, and it is
                 OFF by default. Retention is identify-only (nothing is
                 deleted); the note below says so. -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/backup_auto_section"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/backup_auto_desc"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_auto_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="16dp"
                android:textColor="@color/text"
                android:textIsSelectable="true"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_change_auto_location"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_auto_change_location" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_auto_frequency"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/backup_auto_frequency_label" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_auto_enable"
                    android:textColor="@color/text"
                    android:textSize="16sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_auto_backup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <!-- Persistent inline prerequisite notice (why the switch refused
                 to turn on). Never a toast. -->
            <TextView
                android:id="@+id/text_auto_prereq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Persistent last-result line for automatic runs. -->
            <TextView
                android:id="@+id/text_auto_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/backup_auto_retention_note"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />

            <!-- ============ 7. Reset (destructive; bottom, unchanged) ============ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="@string/memory_controls_section_reset"
                android:textColor="?attr/colorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_memory_reset"
                style="@style/AppButton.Destructive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/memory_controls_reset" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="@string/memory_controls_reset_hint"
                android:textColor="@color/text_subtitle"
                android:textSize="13sp" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
