<!-- Shared "simple" scaffold (owner ruling, July 19 2026, generalized from
     the one-off activity_memory_user_personas.xml): for every
     MemoryScreenActivity screen that never uses the main scaffold's
     reserved action-button/filter/mode-toggle/pending-banner space, so it
     gets the same plain Widget.App.ActionBar header as Characters/
     Companions/Activation Prompts/Profile Image Properties instead of the
     button-aware title in activity_memory_list.xml. Only action_bar/
     btn_back/activity_title, search_bar/field_search, empty_view, list_view
     and btn_add carry ids MemoryScreenActivity reads - the ids for pieces
     no screen on this layout uses (btn_action, btn_action_secondary,
     filter_bar, chips_filter, pending_banner, btn_filter,
     mode_toggle_container, btn_mode_memories, btn_mode_pending,
     mode_pending_count) are simply absent; the base class's null-safe
     findViewById calls make that safe. search_bar/btn_add stay in the XML
     even for a screen that hides one of them (showSearch()==false /
     addButtonText()==null) - the base class already toggles their
     visibility itself, so one shared file covers every combination without
     per-screen duplication. See MemoryScreenActivity.contentLayoutRes().
     Used by: My Personas, Roleplay Characters, Worlds, Party Members,
     Campaigns, Tags - none of the five Roleplay-hub screens wire an action
     icon, secondary action, filter or mode toggle either, so none of them
     needed the reserved space they'd been getting from the main scaffold. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_add"
        style="?attr/extendedFloatingActionButtonPrimaryStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:text="@string/btn_new_memory"
        android:tooltipText="@string/btn_new_memory"
        android:visibility="gone"
        app:elevation="6dp"
        app:icon="@drawable/ic_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_add" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        style="@style/Widget.App.ActionBar">

        <ImageButton
            android:id="@+id/btn_back"
            style="@style/Widget.App.ActionBar.BackButton" />

        <TextView
            android:id="@+id/activity_title"
            style="@style/Widget.App.ActionBar.Title" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/search_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:textColorHint="@color/memory_hint_soft"
        app:boxStrokeColor="@drawable/box_stroke_color"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp"
        app:startIconDrawable="@drawable/ic_search"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/field_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/memory_search_hint"
            android:singleLine="true"
            android:textColorHint="@color/memory_hint_soft" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/empty_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:gravity="center"
        android:paddingTop="48dp"
        android:text="@string/memory_list_empty"
        android:textColor="@color/text_subtitle"
        android:textSize="15sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/search_bar" />

    <ListView
        android:id="@+id/list_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:divider="@null"
        android:paddingVertical="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/search_bar"
        app:layout_constraintVertical_bias="0.0" />
</androidx.constraintlayout.widget.ConstraintLayout>
