<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:transitionName="expand_characters"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/action_bar"
        style="@style/Widget.App.ActionBar">

        <ImageButton
            android:id="@+id/btn_back"
            style="@style/Widget.App.ActionBar.BackButton" />

        <TextView
            android:id="@+id/activity_title"
            style="@style/Widget.App.ActionBar.Title"
            android:text="@string/title_characters" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scrollable"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="24dp">

            <!-- Personas: opens the persona library. Subtitle shows the persona
                 active for this chat. First review slice for the canonical
                 title-plus-subtitle row style. -->
            <LinearLayout
                android:id="@+id/row_personas"
                style="@style/Widget.App.Row.WithSubtitle"
                android:layout_marginTop="16dp">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/tile_personas_title" />

                    <TextView
                        android:id="@+id/text_personas_subtitle"
                        style="@style/Widget.App.Row.Subtitle"
                        android:text="@string/label_tap_to_set" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/tile_personas_title" />
            </LinearLayout>

            <!-- My Personas moved here from the memory manager (owner ruling,
                 July 6 2026): it is the user's self-presentation, an identity
                 row, and carries no memories. -->
            <LinearLayout
                android:id="@+id/row_my_personas"
                style="@style/Widget.App.Row.WithSubtitle">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/mem_pers_title_user_personas" />

                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:text="@string/mm_user_personas_desc" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/mem_pers_title_user_personas" />
            </LinearLayout>

            <!-- Activation prompts: opens the activation prompt library. -->
            <LinearLayout
                android:id="@+id/row_activation_prompts"
                style="@style/Widget.App.Row.WithSubtitle">

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/tile_activation_prompts_title" />

                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:text="@string/tile_activation_prompts_desc" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/tile_activation_prompts_title" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
