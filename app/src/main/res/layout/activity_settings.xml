                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tile_clear_chat">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/tile_documentation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/tile_alert_debug_menu"
                style="@style/Widget.App.Row.WithSubtitle"
                android:paddingHorizontal="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView389">

                <ImageView
                    style="@style/Widget.App.Row.Icon"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_bug"
                    android:tint="?attr/colorPrimary" />

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/tile_alert_debug_menu_title" />

                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:maxLines="3"
                        android:text="@string/tile_alert_debug_menu_desc" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/tile_alert_debug_menu_title" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</LinearLayout>