                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:maxLines="3"
                        android:text="@string/tile_memory_system_desc" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/tile_memory_system_title" />
            </LinearLayout>

            <LinearLayout
