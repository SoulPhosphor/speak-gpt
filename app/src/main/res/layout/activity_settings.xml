                style="@style/Widget.App.Row.WithSubtitle"
                android:paddingHorizontal="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/constraintLayout8">

                <ImageView
                    style="@style/Widget.App.Row.Icon"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chat"
                    android:tint="?attr/colorPrimary" />

                <LinearLayout style="@style/Widget.App.Row.TextColumn">

                    <TextView
                        style="@style/Widget.App.Row.Title"
                        android:text="@string/tile_ai_system_settings_title" />

                    <TextView
                        style="@style/Widget.App.Row.Subtitle"
                        android:maxLines="3"
                        android:text="@string/tile_ai_system_settings_desc" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/tile_ai_system_settings_title" />
            </LinearLayout>

            <LinearLayout
