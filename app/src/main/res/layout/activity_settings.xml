                        android:text="@string/tile_roleplay_desc" />
                </LinearLayout>

                <ImageView
                    style="@style/Widget.App.Row.Chevron"
                    android:contentDescription="@string/tile_roleplay_title" />
            </LinearLayout>

            <LinearLayout
