<resources>
    <!-- Base application theme. -->
    <style name="Theme.App" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_100</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorAccent">@color/accent_900</item>
        <item name="appRowTitleColor">@color/text</item>
        <item name="appRowSubtitleColor">@color/text_subtitle</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:statusBarColor">@color/window_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/window_background</item>
        <item name="android:windowBackground">@color/window_background</item>
        <item name="android:typeface">sans</item>
        <item name="android:fontFamily">@font/roboto_ttf</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.App.BottomSheetDialog</item>
        <!-- Owner ruling (July 2026): buttons are semi-square, not pills. This
             is the single shared shape for every default MaterialButton (Save,
             Add, etc.) across the app; buttons that set an explicit style keep
             theirs. -->
        <item name="materialButtonStyle">@style/App.Button</item>
    </style>

    <!-- Default filled button, reshaped to 4dp corners (owner: no pills). -->
    <style name="App.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.App.Button</item>
    </style>

    <style name="ShapeAppearance.App.Button" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>

    <!-- Canonical app buttons. These preserve the current Material 3 appearance,
         use theme color roles automatically, and expose one named text appearance
         plus one shared corner definition for future app-wide changes. -->
    <style name="ShapeAppearance.AppButton" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/button_corner_radius</item>
    </style>

    <style name="TextAppearance.App.Button" parent="TextAppearance.Material3.LabelLarge" />

    <!-- Filled current button appearance. -->
    <style name="AppButton.Primary" parent="Widget.Material3.Button">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AppButton</item>
        <item name="android:textAppearance">@style/TextAppearance.App.Button</item>
    </style>

    <!-- Outlined current button appearance. -->
    <style name="AppButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AppButton</item>
        <item name="android:textAppearance">@style/TextAppearance.App.Button</item>
    </style>

    <!-- Currently matches Secondary visually. It remains separately named so
         destructive buttons can be changed app-wide later without touching layouts. -->
    <style name="AppButton.Destructive" parent="Widget.Material3.Button.OutlinedButton">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.AppButton</item>
        <item name="android:textAppearance">@style/TextAppearance.App.Button</item>
    </style>

    <!-- Dialog action button. Identical to AppButton.Primary in every respect
         (fill, corner, text appearance, theme color roles) EXCEPT width: a
         full-width (match_parent) primary button is too wide inside a dialog,
         so this variant sizes to a percentage of the dialog content width
         rather than a fixed pixel/dp value (owner rule, July 19 2026 — do
         percentage, not hard px). The width lives here in ONE place; change
         layout_constraintWidth_percent to reshape every dialog action button.
         Requires a ConstraintLayout parent (the width is 0dp + percent, with
         the button centred to its parent) — used by dialog_single_action.xml. -->
    <style name="AppButton.Primary.Dialog" parent="AppButton.Primary">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="layout_constraintWidth_default">percent</item>
        <item name="layout_constraintWidth_percent">0.6</item>
        <item name="layout_constraintStart_toStartOf">parent</item>
        <item name="layout_constraintEnd_toEndOf">parent</item>
        <item name="layout_constraintTop_toTopOf">parent</item>
        <item name="layout_constraintBottom_toBottomOf">parent</item>
    </style>

    <!-- Shared chevron-row styles, preserving the current Memory Manager row
         appearance. Use Widget.App.Row.WithSubtitle when the row has helper text
         and Widget.App.Row.TitleOnly when it does not. Both variants intentionally
         share the same outer geometry; Title and Subtitle own the typography. -->
    <style name="Widget.App.Row" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingVertical">12dp</item>
    </style>

    <style name="Widget.App.Row.WithSubtitle" parent="Widget.App.Row" />

    <style name="Widget.App.Row.TitleOnly" parent="Widget.App.Row" />

    <style name="Widget.App.Row.TextColumn" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="Widget.App.Row.Title" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/appRowTitleColor</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="Widget.App.Row.Subtitle" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">?attr/appRowSubtitleColor</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="Widget.App.Row.Chevron" parent="">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:src">@drawable/ic_chevron_right</item>
        <item name="android:tint">?attr/appRowSubtitleColor</item>
    </style>

    <!-- Leading row icon/avatar (owner request, July 18 2026). Not a new row
         shape — it's one extra piece that composes with the existing
         Widget.App.Row.WithSubtitle / Widget.App.Row.TitleOnly containers as
         the row's first child, before Widget.App.Row.TextColumn. Title and
         subtitle keep using the exact same Widget.App.Row.Title/Subtitle
         styles either way, so a row's text never differs because it has (or
         lacks) a leading icon — there's only one Title style and one
         Subtitle style, period.
         Sized to match the leading identity icon already used on memory rows
         (view_memory_row.xml) for one consistent icon size app-wide.
         Deliberately carries no tint of its own: today's plain vector icons
         set android:tint per instance (matching Widget.App.Row.Chevron's own
         convention), but a future avatar/photo (Characters, Personas) must
         be able to sit in this same slot unforced into a single color, so
         the shared style never bakes one in. -->
    <style name="Widget.App.Row.Icon" parent="">
        <item name="android:layout_width">36dp</item>
        <item name="android:layout_height">36dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:scaleType">centerCrop</item>
    </style>

    <!-- Leading Profile Image preview (profile-images-plan.md, XML STYLE AND
         THEME INTEGRATION REQUIREMENTS: "Widget.App.Row.ProfileImage").
         Completely based on Widget.App.Row.Icon - same slot, same formula -
         and overrides ONLY the size via @dimen/row_profile_image_size, so a
         future change to the shared icon formula (end margin, scale type,
         no-baked-in-tint) flows into both automatically while the two sizes
         stay independent. Used by the Global Default / Personal Default rows
         (Default Images screen) to show the currently assigned picture. -->
    <style name="Widget.App.Row.ProfileImage" parent="Widget.App.Row.Icon">
        <item name="android:layout_width">@dimen/row_profile_image_size</item>
        <item name="android:layout_height">@dimen/row_profile_image_size</item>
    </style>

    <!-- Toggle row (owner request, July 18 2026): a settings row whose
         whole point is flipping a boolean, not navigating anywhere, so it
         has no chevron and always carries a subtitle. Reuses the shared
         Widget.App.Row.Title/Subtitle/TextColumn styles so its text
         matches every other row's typography and inherits future theming
         the same way; only the container geometry here is specific to this
         variant. Matches, unchanged, how the app's one existing toggle row
         (Automatically Apply Model Rules, AI System Settings) already
         looked before conversion — no ripple, no minHeight, not clickable
         itself, since only the switch is the tap target. -->
    <style name="Widget.App.Row.Toggle" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingTop">20dp</item>
    </style>

    <!-- Trailing switch for Widget.App.Row.Toggle. -->
    <style name="Widget.App.Row.Switch" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">12dp</item>
    </style>

    <!-- Screen header (owner ruling, July 19 2026): the solid-color bar with
         a back chevron and a centered title at the top of a full-screen
         activity (seen today on Characters, AI System Settings, and
         others). Until now this was hand-copied XML with no shared style,
         which is how new screens silently drifted from it. Font, size,
         padding, margins and positioning for the whole header now live
         here - change them once and every screen using these styles
         follows. A screen only needs an id on each piece (plus its own
         title text) - everything else, including the ConstraintLayout
         pin-to-parent/centering that makes this portable across screens
         without per-instance constraint XML, is baked in below.
         Deliberately excludes the old per-Activity AMOLED pitch-black
         recolor logic (dynamic background/back-button/status-bar
         recoloring in Kotlin) - the owner says that mechanism is being
         removed and does not want it carried into the new style.
         Rolled out so far only to ProfileImagePropertiesActivity and
         DefaultImagesActivity (activity_profile_image_properties.xml,
         activity_default_images.xml) - intentionally not yet applied to
         any other screen; the owner wants this proven right on new
         screens first before the rest of the app is converted. -->
    <style name="Widget.App.ActionBar" parent="">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?attr/colorSurfaceContainerHigh</item>
        <item name="layout_constraintEnd_toEndOf">parent</item>
        <item name="layout_constraintStart_toStartOf">parent</item>
        <item name="layout_constraintTop_toTopOf">parent</item>
    </style>

    <!-- The leading back button inside Widget.App.ActionBar. -->
    <style name="Widget.App.ActionBar.BackButton" parent="">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:background">@drawable/btn_accent_icon_large_100</item>
        <item name="android:contentDescription">@string/go_back</item>
        <item name="android:src">@drawable/ic_back</item>
        <item name="android:tooltipText">@string/go_back</item>
        <item name="srcCompat">@drawable/ic_back</item>
        <item name="layout_constraintBottom_toBottomOf">parent</item>
        <item name="layout_constraintStart_toStartOf">parent</item>
        <item name="layout_constraintTop_toTopOf">parent</item>
    </style>

    <!-- The centered title inside Widget.App.ActionBar. Only android:text
         is left for the instance to set. -->
    <style name="Widget.App.ActionBar.Title" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_title</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="layout_constraintBottom_toBottomOf">parent</item>
        <item name="layout_constraintEnd_toEndOf">parent</item>
        <item name="layout_constraintStart_toStartOf">parent</item>
        <item name="layout_constraintTop_toTopOf">parent</item>
    </style>

    <style name="BottomNavigationView.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/accent_900</item>
    </style>

    <style name="Theme.Preview" parent="Theme.App">
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/transparent</item>
    </style>

    <style name="AssistantWindowTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AssistantWindowStyle</item>
        <item name="colorPrimary">@color/accent_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_100</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorAccent">@color/accent_900</item>
        <item name="appRowTitleColor">@color/text</item>
        <item name="appRowSubtitleColor">@color/text_subtitle</item>
        <item name="android:windowAnimationStyle">@style/AssistantWindowAnimation</item>
        <item name="android:typeface">sans</item>
        <item name="android:fontFamily">@font/default_font</item>
        <item name="android:backgroundDimAmount">0.4</item>
        <item name="android:windowIsFloating">false</item>
    </style>

    <style name="AssistantWindowAnimation" parent="android:Animation">
        <item name="android:windowEnterAnimation">@anim/assistant_entry</item>
        <item name="android:windowExitAnimation">@anim/assistant_exit</item>
        <item name="android:activityOpenEnterAnimation">@anim/assistant_entry</item>
        <item name="android:activityOpenExitAnimation">@anim/assistant_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/assistant_entry</item>
        <item name="android:activityCloseExitAnimation">@anim/assistant_exit</item>
        <item name="android:inAnimation">@anim/assistant_entry</item>
        <item name="android:outAnimation">@anim/assistant_exit</item>
        <item name="android:fragmentOpenEnterAnimation">@anim/assistant_entry</item>
        <item name="android:fragmentOpenExitAnimation">@anim/assistant_exit</item>
        <item name="android:fragmentCloseEnterAnimation">@anim/assistant_entry</item>
        <item name="android:fragmentCloseExitAnimation">@anim/assistant_exit</item>
    </style>

    <style name="AssistantWindowStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="UI.Fade" parent="Theme.App">
        <item name="android:windowAnimationStyle">@style/Theme.Anim.Fade.Material</item>
    </style>

    <style name="UI.Material" parent="Theme.App">
        <item name="android:windowAnimationStyle">@style/Theme.Anim.Fade.Material</item>
    </style>

    <style name="Theme.Transparent" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/shadow</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">#99000000</item>
        <item name="colorAccent">@color/accent_900</item>
        <item name="colorPrimary">#ff121212</item>
        <item name="colorPrimaryDark">#ff121212</item>
        <item name="appRowTitleColor">@color/text</item>
        <item name="appRowSubtitleColor">@color/text_subtitle</item>
        <item name="android:typeface">sans</item>
        <item name="android:fontFamily">@font/default_font</item>
    </style>

    <style name="Theme.Anim.Fade.Material" parent="@style/Theme.AppCompat">
        <item name="android:windowEnterAnimation">@anim/fade_in</item>
        <item name="android:windowExitAnimation">@anim/fade_out</item>
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_out</item>
    </style>

    <style name="Theme.Anim.Material" parent="@style/Theme.Material3.DayNight.NoActionBar">
        <item name="android:activityOpenEnterAnimation">@anim/mtrl_activity_open_enter</item>
        <item name="android:activityOpenExitAnimation">@anim/mtrl_activity_open_exit</item>
        <item name="android:activityCloseEnterAnimation">@anim/mtrl_activity_close_enter</item>
        <item name="android:activityCloseExitAnimation">@anim/mtrl_activity_close_exit</item>
    </style>

    <style name="App.MaterialAlertDialog" parent="MaterialAlertDialog.Material3">
        <item name="buttonBarNegativeButtonStyle">@style/App.NegativeButtonStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/App.PositiveButtonStyle</item>
    </style>

    <style name="Theme.PWA" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/pwa_accent</item>
        <item name="colorOnPrimary">@color/pwa_background</item>
        <item name="colorSecondary">@color/pwa_accent</item>
        <item name="colorOnSecondary">@color/pwa_background</item>
        <item name="colorAccent">@color/pwa_accent</item>
        <item name="appRowTitleColor">@color/text</item>
        <item name="appRowSubtitleColor">@color/text_subtitle</item>
        <item name="android:statusBarColor">@color/pwa_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/pwa_background</item>
        <item name="android:windowBackground">@color/pwa_background</item>
        <item name="android:windowAnimationStyle">@style/Theme.Anim.Fade.Material</item>
        <item name="android:typeface">sans</item>
        <item name="android:fontFamily">@font/default_font</item>
    </style>

    <style name="App.NegativeButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent_900</item>
    </style>

    <style name="App.PositiveButtonStyle" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent_900</item>
    </style>

    <style name="App.ExposedTextField" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="materialThemeOverlay">@style/ThemeOverlay.Material3.TextInputEditText.OutlinedBox</item>
    </style>

    <style name="ThemeOverlay.App.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Preset color palettes (ui-redesign-plan.md, Phase 0). Each palette is a
         ThemeOverlay applied on top of the activity theme by
         ThemeManager.applyPalette before setContentView. This overlay is
         forced on top of everything else (including the Material dynamic-color
         overlay) as the LAST theme layer applied at runtime, so it is the only
         layer guaranteed to be present when a screen resolves a custom
         attribute like appRowTitleColor/appRowSubtitleColor — defining them on
         Theme.App alone is not enough, since that base layer can sit underneath
         layers that don't carry the attribute forward (this crashed
         CharactersActivity, see git history July 18 2026). Violet reproduces
         the app's original row colors unchanged; a future palette overlay
         redefines these same two items (plus the Material color roles) to
         retheme every canonical row with no layout or style changes. -->
    <style name="ThemeOverlay.Phosphor.Violet" parent="">
        <item name="appRowTitleColor">@color/text</item>
        <item name="appRowSubtitleColor">@color/text_subtitle</item>
    </style>
</resources>
